# Configuracion base detectada para SP1.
# Copia este archivo como security-stack.env y ajustalo en cada servidor.

SERVER_NAME="wifi360.nettplus.net"

IGNORE_IPS="127.0.0.1/8 ::1 10.10.0.0/24 10.88.0.0/24 172.26.0.0/24 190.96.96.0/21"
PUBLIC_IGNORE_IPS="127.0.0.1/8 ::1 10.10.0.0/24 10.88.0.0/24 172.26.0.0/24 190.96.96.0/21"

# El instalador pregunta estos rangos si corre en terminal interactiva.
# Usa no para automatizaciones o yes para forzarlo.
PROMPT_IGNORE_RANGES="auto"

NGINX_ACCESS_LOG="/var/log/nginx/access.log"
NGINX_ERROR_LOG="/var/log/nginx/error.log"

# Define esto solo en el servidor donde vayas a enviar alertas.
DISCORD_WEBHOOK_URL=""

ENABLE_UFW="yes"
HTTP_ALLOW_CIDR="190.96.96.0/21"
HTTPS_ALLOW_CIDR="any"

# Importante: si lo llenas, el instalador permitira SSH solo desde esa red/IP.
# Ejemplo: SSH_ALLOW_CIDR="10.10.0.0/24"
SSH_ALLOW_CIDR=""
ENABLE_WIREGUARD="auto"
WIREGUARD_ALLOW_CIDR="190.96.96.0/21"

ENABLE_MODSECURITY="yes"
MODSEC_RULE_ENGINE="On"
CRS_INSTALL_DIR="/etc/nginx/owasp-modsecurity-crs"
CRS_REPO="https://github.com/coreruleset/coreruleset.git"
CRS_VERSION="v4.12.0"
BUILD_MODSECURITY_FROM_SOURCE="auto"
MODSECURITY_REPO="https://github.com/owasp-modsecurity/ModSecurity.git"
MODSECURITY_VERSION="v3/master"
MODSECURITY_NGINX_REPO="https://github.com/owasp-modsecurity/ModSecurity-nginx.git"
NGINX_SOURCE_VERSION="auto"

ENABLE_FAIL2BAN="yes"
ENABLE_MONITOR_TOOLS="yes"

# Threat intelligence blocklists.
# Fuentes soportadas: spamhaus_drop abuseipdb
ENABLE_THREAT_INTEL="yes"
THREAT_INTEL_SOURCES="spamhaus_drop"
THREAT_INTEL_IGNORE_CIDRS="127.0.0.1/8 ::1 10.10.0.0/24 10.88.0.0/24 172.26.0.0/24 190.96.96.0/21"
ABUSEIPDB_API_KEY=""
ABUSEIPDB_CONFIDENCE_MINIMUM="90"

# nftables early drop.
# Usa security-early-drop-nft.service; no depende de nftables.service.
ENABLE_EARLY_DROP_NFT="auto"
BLOCK_NETWORKS_FILE="./security-nft-blocks.txt"
DEFAULT_BLOCK_NETWORKS=""

# SP1 recibe ruido externo/NAT con SRC 172.26.x.x en UFW BLOCK.
# Esto permite sugerir/bloquear esas fuentes sin confiar todo RFC1918.
TRUST_PRIVATE_CIDRS="no"

# Pool local poolvlan11: 172.26.0.2-172.26.0.254.
# Aunque el resto de RFC1918 no sea confiable en este borde, este /24 no se bloquea.
TRUSTED_CIDRS="127.0.0.1/8 10.10.0.0/24 10.88.0.0/24 172.26.0.0/24 190.96.96.0/21"

# Auto-ban desde logs UFW: usar nftables para no llenar UFW con IPs individuales.
AUTO_BAN_BACKEND="nft"
AUTO_BAN_NFT_PREFIX="24"
