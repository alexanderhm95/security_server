# Copia este archivo a security-stack.env y ajusta cada servidor.

# Dominio principal usado en pruebas locales. No edita certificados.
SERVER_NAME="example.com"

# Redes/IPs que nunca debe banear Fail2Ban.
IGNORE_IPS="127.0.0.1/8 ::1 10.10.0.0/24"
PUBLIC_IGNORE_IPS="127.0.0.1/8 ::1 10.10.0.0/24"

# Logs que usaran las jails de Nginx. El instalador de Fail2Ban actual acepta uno principal.
NGINX_ACCESS_LOG="/var/log/nginx/access.log"
NGINX_ERROR_LOG="/var/log/nginx/error.log"

# Si quieres alertas Discord, define el webhook aqui o como variable de entorno.
DISCORD_WEBHOOK_URL=""

# UFW: por seguridad, SSH solo se limita si defines SSH_ALLOW_CIDR.
ENABLE_UFW="yes"
HTTP_ALLOW_CIDR="any"
HTTPS_ALLOW_CIDR="any"
SSH_ALLOW_CIDR=""
ENABLE_WIREGUARD="auto"
WIREGUARD_ALLOW_CIDR="any"

# ModSecurity / OWASP CRS.
ENABLE_MODSECURITY="yes"
MODSEC_RULE_ENGINE="On"
CRS_INSTALL_DIR="/etc/nginx/owasp-modsecurity-crs"
CRS_REPO="https://github.com/coreruleset/coreruleset.git"
CRS_VERSION="v4.12.0"
BUILD_MODSECURITY_FROM_SOURCE="auto"
MODSECURITY_REPO="https://github.com/owasp-modsecurity/ModSecurity.git"
MODSECURITY_VERSION="v3/master"
MODSECURITY_NGINX_REPO="https://github.com/owasp-modsecurity/ModSecurity-nginx.git"
NGINX_SOURCE_VERSION="auto"

# Herramientas operativas.
ENABLE_FAIL2BAN="yes"
ENABLE_MONITOR_TOOLS="yes"
